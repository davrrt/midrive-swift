{
  "name": "fleet-dashboard",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"yarn dev:frontend\" \"yarn dev:backend\"",
    "frontend": "yarn workspace fleet-dashboard-frontend",
    "backend": "yarn workspace fleet-dashboard-backend",
    "dev:frontend": "yarn workspace fleet-dashboard-frontend dev",
    "dev:backend": "yarn workspace fleet-dashboard-backend dev",
    "build:frontend": "yarn workspace fleet-dashboard-frontend build",
    "build:backend": "yarn workspace fleet-dashboard-backend build",
    "build": "yarn build:frontend && yarn build:backend"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  },
  "packageManager": "yarn@4.10.3+sha512.c38cafb5c7bb273f3926d04e55e1d8c9dfa7d9c3ea1f36a4868fa028b9e5f72298f0b7f401ad5eb921749eb012eb1c3bb74bf7503df3ee43fd600d14a018266f"
}
